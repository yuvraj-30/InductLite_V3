{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "doctor": "npx expo-doctor",
    "prebuild": "expo prebuild",
    "release:check": "node ./scripts/validate-release-config.mjs",
    "build:ios": "npx eas build --platform ios --profile production",
    "build:android": "npx eas build --platform android --profile production",
    "build:ios:ready": "npm run release:check && npx eas build --platform ios --profile production",
    "build:android:ready": "npm run release:check && npx eas build --platform android --profile production"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "buffer": "^6.0.3",
    "expo": "~55.0.5",
    "expo-application": "^55.0.8",
    "expo-constants": "^55.0.7",
    "expo-device": "^55.0.9",
    "expo-location": "^55.1.2",
    "expo-secure-store": "^55.0.8",
    "expo-status-bar": "~55.0.4",
    "expo-task-manager": "^55.0.9",
    "react": "19.2.4",
    "react-native": "0.83.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "react"
      ]
    }
  },
  "private": true
}

