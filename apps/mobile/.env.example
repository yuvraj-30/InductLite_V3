# App identity placeholders (replace before production build)
EXPO_PUBLIC_MOBILE_APP_NAME=InductLite Mobile
EXPO_PUBLIC_MOBILE_SLUG=inductlite-mobile
EXPO_PUBLIC_MOBILE_SCHEME=inductlite
EXPO_PUBLIC_MOBILE_IOS_BUNDLE_ID=com.placeholder.inductlite.mobile
EXPO_PUBLIC_MOBILE_ANDROID_PACKAGE=com.placeholder.inductlite.mobile

# Runtime + distribution placeholders (safe to expose)
EXPO_PUBLIC_MOBILE_API_BASE_URL=http://127.0.0.1:3000
EXPO_PUBLIC_MOBILE_WRAPPER_RUNTIME=expo-managed
EXPO_PUBLIC_MOBILE_RELEASE_CHANNEL=development
EXPO_PUBLIC_MOBILE_IOS_APPSTORE_URL=https://apps.apple.com/app/id0000000000
EXPO_PUBLIC_MOBILE_ANDROID_PLAY_URL=https://play.google.com/store/apps/details?id=com.placeholder.inductlite.mobile
EXPO_PUBLIC_MOBILE_IOS_MIN_VERSION=1.0.0
EXPO_PUBLIC_MOBILE_ANDROID_MIN_VERSION=1.0.0
EXPO_PUBLIC_MOBILE_EAS_PROJECT_ID=00000000-0000-0000-0000-000000000000

# Build-time account placeholders (do not use EXPO_PUBLIC for secrets)
