// Prisma schema for InductLite multi-tenant SaaS
// All tenant-owned entities include company_id for scoping

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_DIRECT_URL")
}

// ============================================================================
// CORE ENTITIES
// ============================================================================

model Company {
  id                             String      @id @default(cuid())
  name                           String
  slug                           String      @unique
  product_plan                   CompanyPlan @default(STANDARD)
  sso_config                     Json?
  feature_overrides              Json?
  feature_credit_overrides       Json?
  retention_days                 Int         @default(365) // Sign-in register retention policy
  induction_retention_days       Int         @default(365) // Induction evidence retention policy
  audit_retention_days           Int         @default(90) // Audit trail retention policy
  incident_retention_days        Int         @default(1825) // 5 years default for incident evidence
  emergency_drill_retention_days Int         @default(1825) // 5 years default for drill evidence
  compliance_legal_hold          Boolean     @default(false)
  compliance_legal_hold_reason   String?
  compliance_legal_hold_set_at   DateTime?
  created_at                     DateTime    @default(now())
  updated_at                     DateTime    @updatedAt

  // Relations
  users                       User[]
  sites                       Site[]
  induction_templates         InductionTemplate[]
  contractors                 Contractor[]
  hazard_register_entries     HazardRegisterEntry[]
  emergency_contacts          SiteEmergencyContact[]
  emergency_procedures        SiteEmergencyProcedure[]
  emergency_drills            EmergencyDrill[]
  evacuation_events           EvacuationEvent[]
  evacuation_attendances      EvacuationAttendance[]
  pending_sign_in_escalations PendingSignInEscalation[]
  incident_reports            IncidentReport[]
  legal_document_versions     LegalDocumentVersion[]
  site_manager_assignments    SiteManagerAssignment[]
  magic_link_tokens           MagicLinkToken[]
  pre_registration_invites    PreRegistrationInvite[]
  sign_in_records             SignInRecord[]
  export_jobs                 ExportJob[]
  audit_logs                  AuditLog[]
  email_notifications         EmailNotification[]
  outbound_webhook_deliveries OutboundWebhookDelivery[]
  induction_quiz_attempts     InductionQuizAttempt[]

  @@index([slug])
}

model User {
  id                  String    @id @default(cuid())
  company_id          String
  email               String    @unique
  password_hash       String
  totp_secret         String?
  identity_provider   String?
  identity_subject    String?
  directory_synced_at DateTime?
  name                String
  role                UserRole  @default(VIEWER)
  is_active           Boolean   @default(true)
  failed_logins       Int       @default(0)
  locked_until        DateTime?
  last_login_at       DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  // Relations
  company                      Company                   @relation(fields: [company_id], references: [id], onDelete: Cascade)
  audit_logs                   AuditLog[]                @relation("user_audit_logs")
  sign_outs                    SignInRecord[]            @relation("signed_out_by")
  hazards_identified           HazardRegisterEntry[]     @relation("hazard_identified_by")
  hazards_closed               HazardRegisterEntry[]     @relation("hazard_closed_by")
  incidents_reported           IncidentReport[]          @relation("incident_reported_by")
  incidents_resolved           IncidentReport[]          @relation("incident_resolved_by")
  incidents_worksafe_notified  IncidentReport[]          @relation("incident_worksafe_notified_by")
  emergency_drills_tested      EmergencyDrill[]          @relation("emergency_drill_tested_by")
  evacuation_events_started    EvacuationEvent[]         @relation("evacuation_event_started_by")
  evacuation_events_closed     EvacuationEvent[]         @relation("evacuation_event_closed_by")
  evacuation_attendance_marked EvacuationAttendance[]    @relation("evacuation_attendance_accounted_by")
  sign_in_escalations_reviewed PendingSignInEscalation[] @relation("sign_in_escalation_reviewed_by")
  legal_documents_authored     LegalDocumentVersion[]    @relation("legal_document_author")
  sites_managed                SiteManagerAssignment[]   @relation("site_manager_user")
  pre_registration_invites     PreRegistrationInvite[]   @relation("pre_registration_invite_creator")
  notifications                EmailNotification[]

  @@unique([company_id, email])
  @@unique([company_id, identity_provider, identity_subject])
  @@index([company_id])
  @@index([company_id, identity_subject])
  @@index([email])
}

enum UserRole {
  ADMIN
  SITE_MANAGER
  VIEWER
}

enum CompanyPlan {
  STANDARD
  PLUS
  PRO
}

// ============================================================================
// SITES & PUBLIC LINKS
// ============================================================================

model Site {
  id                       String   @id @default(cuid())
  company_id               String
  name                     String
  address                  String?
  description              String?
  location_latitude        Float?
  location_longitude       Float?
  location_radius_m        Int?
  feature_overrides        Json?
  feature_credit_overrides Json?
  is_active                Boolean  @default(true)
  access_control           Json?
  webhooks                 Json?
  lms_connector            Json?
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  // Relations
  company                     Company                   @relation(fields: [company_id], references: [id], onDelete: Cascade)
  templates                   InductionTemplate[]       @relation("template_site")
  public_links                SitePublicLink[]
  sign_in_records             SignInRecord[]
  hazard_register_entries     HazardRegisterEntry[]
  emergency_contacts          SiteEmergencyContact[]
  emergency_procedures        SiteEmergencyProcedure[]
  emergency_drills            EmergencyDrill[]
  evacuation_events           EvacuationEvent[]
  evacuation_attendances      EvacuationAttendance[]
  pending_sign_in_escalations PendingSignInEscalation[]
  incident_reports            IncidentReport[]
  site_managers               SiteManagerAssignment[]   @relation("site_manager_site")
  pre_registration_invites    PreRegistrationInvite[]
  outbound_webhook_deliveries OutboundWebhookDelivery[]
  induction_quiz_attempts     InductionQuizAttempt[]

  @@unique([company_id, name])
  @@index([company_id])
  @@index([company_id, is_active])
}

model SitePublicLink {
  id         String    @id @default(cuid())
  site_id    String
  slug       String    @unique // Public URL slug for QR code
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())
  rotated_at DateTime  @default(now()) // Last time slug was rotated
  expires_at DateTime? // Optional expiry

  // Relations
  site Site @relation(fields: [site_id], references: [id], onDelete: Cascade)

  @@index([slug])
  @@index([site_id])
}

// ============================================================================
// INDUCTION TEMPLATES & QUESTIONS
// ============================================================================

model InductionTemplate {
  id                      String    @id @default(cuid())
  company_id              String
  site_id                 String? // null = company-wide default template
  name                    String
  description             String?
  version                 Int       @default(1)
  is_published            Boolean   @default(false)
  is_default              Boolean   @default(false) // Company-wide default (only when site_id is null)
  is_archived             Boolean   @default(false) // Immutable once archived (old versions)
  published_at            DateTime?
  force_reinduction       Boolean   @default(false)
  quiz_scoring_enabled    Boolean   @default(false)
  quiz_pass_threshold     Int       @default(80)
  quiz_max_attempts       Int       @default(3)
  quiz_cooldown_minutes   Int       @default(15)
  quiz_required_for_entry Boolean   @default(true)
  induction_media         Json?
  induction_languages     Json?
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  // Relations
  company       Company                @relation(fields: [company_id], references: [id], onDelete: Cascade)
  site          Site?                  @relation("template_site", fields: [site_id], references: [id], onDelete: Cascade)
  questions     InductionQuestion[]
  responses     InductionResponse[]
  quiz_attempts InductionQuizAttempt[]

  // Business rules enforced via repository layer:
  // - At most one is_published=true template per site (where site_id is not null)
  // - At most one is_published=true AND is_default=true per company (where site_id is null)
  @@unique([company_id, name, version])
  @@index([company_id])
  @@index([company_id, site_id])
  @@index([company_id, is_default, is_published])
  @@index([site_id, is_published])
}

model InductionQuestion {
  id             String       @id @default(cuid())
  template_id    String
  question_text  String
  question_type  QuestionType
  options        Json? // For MULTIPLE_CHOICE, CHECKBOX types
  is_required    Boolean      @default(true)
  display_order  Int
  correct_answer Json? // For validation (if applicable)
  logic          Json?
  red_flag       Boolean      @default(false)
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt

  // Relations
  template InductionTemplate @relation(fields: [template_id], references: [id], onDelete: Cascade)

  @@index([template_id])
  @@index([template_id, display_order])
}

enum QuestionType {
  TEXT
  MULTIPLE_CHOICE
  CHECKBOX
  YES_NO
  ACKNOWLEDGMENT
}

// ============================================================================
// SIGN-IN RECORDS & INDUCTION RESPONSES
// ============================================================================

model SignInRecord {
  id                     String      @id @default(cuid())
  company_id             String
  site_id                String
  idempotency_key        String? // Public sign-in dedupe key (client generated)
  visitor_name           String
  visitor_phone          String
  visitor_email          String?
  employer_name          String? // For contractor matching
  visitor_type           VisitorType @default(CONTRACTOR)
  hasAcceptedTerms       Boolean     @default(false)
  termsAcceptedAt        DateTime?
  terms_version_id       String?
  privacy_version_id     String?
  consent_statement      String?
  sign_in_ts             DateTime    @default(now())
  location_latitude      Float?
  location_longitude     Float?
  location_accuracy_m    Float?
  location_distance_m    Float?
  location_within_radius Boolean?
  location_captured_at   DateTime?
  sign_out_ts            DateTime? // null = currently on site
  signed_out_by          String? // User ID who signed out the visitor (null = self-signout)
  sign_out_token         String? // Hashed token for self sign-out
  sign_out_token_exp     DateTime? // Token expiry
  notes                  String?
  created_at             DateTime    @default(now())

  // Relations
  company                Company                  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  site                   Site                     @relation(fields: [site_id], references: [id], onDelete: Cascade)
  terms_version          LegalDocumentVersion?    @relation("sign_in_terms_version", fields: [terms_version_id], references: [id], onDelete: SetNull)
  privacy_version        LegalDocumentVersion?    @relation("sign_in_privacy_version", fields: [privacy_version_id], references: [id], onDelete: SetNull)
  signed_out_user        User?                    @relation("signed_out_by", fields: [signed_out_by], references: [id], onDelete: SetNull)
  induction_response     InductionResponse?
  approved_escalation    PendingSignInEscalation? @relation("escalation_approved_signin")
  incident_reports       IncidentReport[]
  evacuation_attendances EvacuationAttendance[]

  @@unique([company_id, idempotency_key])
  @@index([company_id])
  @@index([company_id, site_id])
  @@index([company_id, sign_in_ts])
  @@index([company_id, sign_out_ts])
  @@index([site_id, sign_in_ts])
  @@index([signed_out_by])
  @@index([sign_out_token])
  @@index([terms_version_id])
  @@index([privacy_version_id])
}

enum VisitorType {
  CONTRACTOR
  VISITOR
  EMPLOYEE
  DELIVERY
}

enum SignInEscalationStatus {
  PENDING
  APPROVED
  DENIED
}

enum InductionCompetencyStatus {
  SELF_DECLARED
  SUPERVISOR_APPROVED
}

model PendingSignInEscalation {
  id                         String                 @id @default(cuid())
  company_id                 String
  site_id                    String
  idempotency_key            String
  status                     SignInEscalationStatus @default(PENDING)
  visitor_name               String
  visitor_phone              String
  visitor_email              String?
  employer_name              String?
  visitor_type               VisitorType            @default(CONTRACTOR)
  role_on_site               String?
  hasAcceptedTerms           Boolean                @default(false)
  termsAcceptedAt            DateTime?
  terms_version_id           String?
  privacy_version_id         String?
  consent_statement          String?
  template_id                String
  template_version           Int
  /// @Encrypted: Do not store PII here without encryption.
  answers                    Json
  signature_data             String?
  red_flag_question_ids      Json
  red_flag_questions         Json
  notification_targets       Int                    @default(0)
  notifications_queued       Int                    @default(0)
  submitted_at               DateTime               @default(now())
  reviewed_at                DateTime?
  reviewed_by                String?
  review_notes               String?
  approved_sign_in_record_id String?                @unique
  created_at                 DateTime               @default(now())
  updated_at                 DateTime               @updatedAt

  company                 Company       @relation(fields: [company_id], references: [id], onDelete: Cascade)
  site                    Site          @relation(fields: [site_id], references: [id], onDelete: Cascade)
  reviewed_by_user        User?         @relation("sign_in_escalation_reviewed_by", fields: [reviewed_by], references: [id], onDelete: SetNull)
  approved_sign_in_record SignInRecord? @relation("escalation_approved_signin", fields: [approved_sign_in_record_id], references: [id], onDelete: SetNull)

  @@unique([company_id, idempotency_key])
  @@index([company_id])
  @@index([company_id, status])
  @@index([company_id, site_id, status])
  @@index([company_id, submitted_at])
  @@index([reviewed_by])
}

model PreRegistrationInvite {
  id                     String      @id @default(cuid())
  company_id             String
  site_id                String
  created_by             String?
  token_hash             String      @unique
  visitor_name           String
  visitor_phone          String
  visitor_email          String?
  employer_name          String?
  visitor_type           VisitorType @default(CONTRACTOR)
  role_on_site           String?
  notes                  String?
  is_active              Boolean     @default(true)
  expires_at             DateTime
  used_at                DateTime?
  used_sign_in_record_id String?
  created_at             DateTime    @default(now())
  updated_at             DateTime    @updatedAt

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  site    Site    @relation(fields: [site_id], references: [id], onDelete: Cascade)
  creator User?   @relation("pre_registration_invite_creator", fields: [created_by], references: [id], onDelete: SetNull)

  @@index([company_id])
  @@index([company_id, site_id])
  @@index([company_id, site_id, is_active])
  @@index([company_id, expires_at])
  @@index([company_id, used_at])
  @@index([created_by])
}

model InductionResponse {
  id                       String                    @id @default(cuid())
  sign_in_record_id        String                    @unique
  template_id              String
  template_version         Int // Snapshot of version at time of completion
  /// @Encrypted: Do not store PII here without encryption.
  answers                  Json // Array of { question_id, answer }
  completion_snapshot      Json?
  signature_url            String? // Base64 or R2 URL
  signature_hash           String?
  signature_mime_type      String?
  signature_size_bytes     Int?
  signature_captured_at    DateTime?
  completed_at             DateTime                  @default(now())
  passed                   Boolean                   @default(true)
  competency_status        InductionCompetencyStatus @default(SELF_DECLARED)
  briefing_acknowledged_at DateTime?
  refresher_due_at         DateTime?
  supervisor_verified_by   String?
  supervisor_verified_at   DateTime?

  // Relations
  sign_in_record SignInRecord      @relation(fields: [sign_in_record_id], references: [id], onDelete: Cascade)
  template       InductionTemplate @relation(fields: [template_id], references: [id], onDelete: Cascade)

  @@index([template_id])
  @@index([sign_in_record_id])
  @@index([signature_hash])
  @@index([competency_status])
  @@index([refresher_due_at])
  @@index([supervisor_verified_by])
}

model InductionQuizAttempt {
  id                 String    @id @default(cuid())
  company_id         String
  site_id            String
  template_id        String
  visitor_phone_hash String
  failed_attempts    Int       @default(0)
  cooldown_until     DateTime?
  last_attempt_at    DateTime?
  last_score_percent Int?
  last_passed        Boolean?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  company  Company           @relation(fields: [company_id], references: [id], onDelete: Cascade)
  site     Site              @relation(fields: [site_id], references: [id], onDelete: Cascade)
  template InductionTemplate @relation(fields: [template_id], references: [id], onDelete: Cascade)

  @@unique([company_id, site_id, template_id, visitor_phone_hash])
  @@index([company_id])
  @@index([company_id, site_id, template_id])
  @@index([company_id, cooldown_until])
}

model HazardRegisterEntry {
  id            String          @id @default(cuid())
  company_id    String
  site_id       String
  title         String
  description   String?
  risk_level    HazardRiskLevel @default(MEDIUM)
  status        HazardStatus    @default(OPEN)
  controls      Json?
  identified_at DateTime        @default(now())
  identified_by String?
  closed_at     DateTime?
  closed_by     String?
  created_at    DateTime        @default(now())
  updated_at    DateTime        @updatedAt

  company            Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  site               Site    @relation(fields: [site_id], references: [id], onDelete: Cascade)
  identified_by_user User?   @relation("hazard_identified_by", fields: [identified_by], references: [id], onDelete: SetNull)
  closed_by_user     User?   @relation("hazard_closed_by", fields: [closed_by], references: [id], onDelete: SetNull)

  @@index([company_id])
  @@index([company_id, site_id])
  @@index([company_id, status])
  @@index([company_id, risk_level])
  @@index([identified_by])
  @@index([closed_by])
}

enum HazardRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum HazardStatus {
  OPEN
  IN_PROGRESS
  MITIGATED
  CLOSED
}

model SiteEmergencyContact {
  id         String   @id @default(cuid())
  company_id String
  site_id    String
  name       String
  role       String?
  phone      String
  email      String?
  notes      String?
  priority   Int      @default(0)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  site    Site    @relation(fields: [site_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([company_id, site_id])
  @@index([company_id, site_id, is_active])
  @@index([site_id, priority])
}

model SiteEmergencyProcedure {
  id           String   @id @default(cuid())
  company_id   String
  site_id      String
  title        String
  instructions String
  sort_order   Int      @default(0)
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  site    Site    @relation(fields: [site_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([company_id, site_id])
  @@index([company_id, site_id, is_active])
  @@index([site_id, sort_order])
}

model LegalDocumentVersion {
  id            String            @id @default(cuid())
  company_id    String
  document_type LegalDocumentType
  version       Int
  title         String?
  content_hash  String
  effective_at  DateTime          @default(now())
  created_by    String?
  created_at    DateTime          @default(now())
  updated_at    DateTime          @updatedAt

  company         Company        @relation(fields: [company_id], references: [id], onDelete: Cascade)
  author          User?          @relation("legal_document_author", fields: [created_by], references: [id], onDelete: SetNull)
  sign_in_terms   SignInRecord[] @relation("sign_in_terms_version")
  sign_in_privacy SignInRecord[] @relation("sign_in_privacy_version")

  @@unique([company_id, document_type, version])
  @@index([company_id])
  @@index([company_id, document_type, effective_at])
  @@index([created_by])
}

enum LegalDocumentType {
  TERMS
  PRIVACY
}

model IncidentReport {
  id                        String           @id @default(cuid())
  company_id                String
  site_id                   String
  sign_in_record_id         String?
  incident_type             IncidentType     @default(INCIDENT)
  severity                  IncidentSeverity @default(MEDIUM)
  status                    IncidentStatus   @default(OPEN)
  title                     String
  description               String?
  immediate_actions         String?
  occurred_at               DateTime         @default(now())
  is_notifiable             Boolean          @default(false)
  worksafe_notified_at      DateTime?
  worksafe_reference_number String?
  worksafe_notified_by      String?
  legal_hold                Boolean          @default(false)
  retention_expires_at      DateTime?
  reported_by               String?
  resolved_at               DateTime?
  resolved_by               String?
  created_at                DateTime         @default(now())
  updated_at                DateTime         @updatedAt

  company                   Company       @relation(fields: [company_id], references: [id], onDelete: Cascade)
  site                      Site          @relation(fields: [site_id], references: [id], onDelete: Cascade)
  sign_in_record            SignInRecord? @relation(fields: [sign_in_record_id], references: [id], onDelete: SetNull)
  reported_by_user          User?         @relation("incident_reported_by", fields: [reported_by], references: [id], onDelete: SetNull)
  resolved_by_user          User?         @relation("incident_resolved_by", fields: [resolved_by], references: [id], onDelete: SetNull)
  worksafe_notified_by_user User?         @relation("incident_worksafe_notified_by", fields: [worksafe_notified_by], references: [id], onDelete: SetNull)

  @@index([company_id])
  @@index([company_id, site_id])
  @@index([company_id, status])
  @@index([company_id, incident_type])
  @@index([company_id, severity])
  @@index([company_id, occurred_at])
  @@index([company_id, is_notifiable])
  @@index([company_id, legal_hold])
  @@index([company_id, retention_expires_at])
  @@index([sign_in_record_id])
  @@index([reported_by])
  @@index([resolved_by])
  @@index([worksafe_notified_by])
}

model EmergencyDrill {
  id                   String             @id @default(cuid())
  company_id           String
  site_id              String
  drill_type           EmergencyDrillType @default(EVACUATION)
  scenario             String
  outcome_notes        String?
  follow_up_actions    String?
  conducted_at         DateTime           @default(now())
  next_due_at          DateTime?
  tested_by            String?
  legal_hold           Boolean            @default(false)
  retention_expires_at DateTime?
  created_at           DateTime           @default(now())
  updated_at           DateTime           @updatedAt

  company        Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  site           Site    @relation(fields: [site_id], references: [id], onDelete: Cascade)
  tested_by_user User?   @relation("emergency_drill_tested_by", fields: [tested_by], references: [id], onDelete: SetNull)

  @@index([company_id])
  @@index([company_id, site_id])
  @@index([company_id, conducted_at])
  @@index([company_id, legal_hold])
  @@index([company_id, retention_expires_at])
  @@index([tested_by])
}

model EvacuationEvent {
  id              String                @id @default(cuid())
  company_id      String
  site_id         String
  status          EvacuationEventStatus @default(ACTIVE)
  started_at      DateTime              @default(now())
  started_by      String?
  closed_at       DateTime?
  closed_by       String?
  notes           String?
  total_people    Int                   @default(0)
  accounted_count Int                   @default(0)
  missing_count   Int                   @default(0)
  created_at      DateTime              @default(now())
  updated_at      DateTime              @updatedAt

  company         Company                @relation(fields: [company_id], references: [id], onDelete: Cascade)
  site            Site                   @relation(fields: [site_id], references: [id], onDelete: Cascade)
  started_by_user User?                  @relation("evacuation_event_started_by", fields: [started_by], references: [id], onDelete: SetNull)
  closed_by_user  User?                  @relation("evacuation_event_closed_by", fields: [closed_by], references: [id], onDelete: SetNull)
  attendances     EvacuationAttendance[]

  @@index([company_id])
  @@index([company_id, site_id, status])
  @@index([company_id, started_at])
  @@index([started_by])
  @@index([closed_by])
}

model EvacuationAttendance {
  id                String                     @id @default(cuid())
  company_id        String
  event_id          String
  site_id           String
  sign_in_record_id String
  visitor_name      String
  visitor_type      VisitorType
  status            EvacuationAttendanceStatus @default(MISSING)
  accounted_at      DateTime?
  accounted_by      String?
  created_at        DateTime                   @default(now())
  updated_at        DateTime                   @updatedAt

  company           Company         @relation(fields: [company_id], references: [id], onDelete: Cascade)
  site              Site            @relation(fields: [site_id], references: [id], onDelete: Cascade)
  event             EvacuationEvent @relation(fields: [event_id], references: [id], onDelete: Cascade)
  sign_in_record    SignInRecord    @relation(fields: [sign_in_record_id], references: [id], onDelete: Cascade)
  accounted_by_user User?           @relation("evacuation_attendance_accounted_by", fields: [accounted_by], references: [id], onDelete: SetNull)

  @@unique([event_id, sign_in_record_id])
  @@index([company_id])
  @@index([company_id, event_id])
  @@index([company_id, site_id, status])
  @@index([sign_in_record_id])
  @@index([accounted_by])
}

enum EvacuationEventStatus {
  ACTIVE
  CLOSED
}

enum EvacuationAttendanceStatus {
  ACCOUNTED
  MISSING
}

enum EmergencyDrillType {
  EVACUATION
  FIRE
  EARTHQUAKE
  MEDICAL
  OTHER
}

enum IncidentType {
  INCIDENT
  NEAR_MISS
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  CLOSED
}

model EmailNotification {
  id         String             @id @default(cuid())
  company_id String
  user_id    String? // Target user
  to         String
  subject    String
  body       String
  status     NotificationStatus @default(PENDING)
  error      String?
  attempts   Int                @default(0)
  last_tried DateTime?
  sent_at    DateTime?
  created_at DateTime           @default(now())

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([company_id])
  @@index([user_id])
  @@index([status])
  @@index([created_at])
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum DemoBookingNotificationStatus {
  PENDING
  SENT
  FAILED
}

model DemoBookingRequest {
  id                         String                        @id @default(cuid())
  full_name                  String
  work_email                 String
  company_name               String
  phone                      String?
  site_count                 Int?
  target_go_live_date        DateTime?
  requirements               String
  source_path                String                        @default("/demo")
  ip_hash                    String?
  user_agent                 String?
  notification_status        DemoBookingNotificationStatus @default(PENDING)
  notification_recipients    Json?
  notification_attempted_at  DateTime?
  notification_sent_at       DateTime?
  notification_error_message String?
  created_at                 DateTime                      @default(now())
  updated_at                 DateTime                      @updatedAt

  @@index([created_at])
  @@index([notification_status, created_at])
}

model OutboundWebhookDelivery {
  id                 String                @id @default(cuid())
  company_id         String
  site_id            String
  event_type         String
  target_url         String
  payload            Json
  status             WebhookDeliveryStatus @default(PENDING)
  attempts           Int                   @default(0)
  max_attempts       Int                   @default(5)
  next_attempt_at    DateTime              @default(now())
  last_attempt_at    DateTime?
  last_status_code   Int?
  last_error         String?
  last_response_body String?
  sent_at            DateTime?
  created_at         DateTime              @default(now())
  updated_at         DateTime              @updatedAt

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  site    Site    @relation(fields: [site_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([company_id, status])
  @@index([status, next_attempt_at])
  @@index([site_id, status])
  @@index([created_at])
}

enum WebhookDeliveryStatus {
  PENDING
  PROCESSING
  RETRYING
  SENT
  DEAD
}

// ============================================================================
// CONTRACTORS & DOCUMENTS
// ============================================================================

model Contractor {
  id            String   @id @default(cuid())
  company_id    String
  name          String // Company/individual name
  contact_name  String?
  contact_email String?
  contact_phone String?
  trade         String? // e.g., Electrician, Plumber
  notes         String?
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Relations
  company           Company              @relation(fields: [company_id], references: [id], onDelete: Cascade)
  documents         ContractorDocument[]
  magic_link_tokens MagicLinkToken[]

  @@unique([company_id, name])
  @@index([company_id])
  @@index([company_id, contact_email])
  @@index([company_id, is_active])
}

model SiteManagerAssignment {
  id         String   @id @default(cuid())
  company_id String
  site_id    String
  user_id    String
  created_at DateTime @default(now())

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  site    Site    @relation("site_manager_site", fields: [site_id], references: [id], onDelete: Cascade)
  user    User    @relation("site_manager_user", fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([company_id, site_id, user_id])
  @@index([company_id])
  @@index([company_id, user_id])
  @@index([company_id, site_id])
}

model MagicLinkToken {
  id            String    @id @default(cuid())
  company_id    String
  contractor_id String
  token_hash    String    @unique
  expires_at    DateTime
  used_at       DateTime?
  created_at    DateTime  @default(now())

  company    Company    @relation(fields: [company_id], references: [id], onDelete: Cascade)
  contractor Contractor @relation(fields: [contractor_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([company_id, contractor_id])
  @@index([expires_at])
}

model ContractorDocument {
  id            String       @id @default(cuid())
  contractor_id String
  document_type DocumentType
  file_name     String
  file_path     String // Storage path (S3 key or local path)
  file_size     Int // bytes
  mime_type     String
  expires_at    DateTime? // null = no expiry
  uploaded_at   DateTime     @default(now())
  notes         String?

  // Relations
  contractor Contractor @relation(fields: [contractor_id], references: [id], onDelete: Cascade)

  @@index([contractor_id])
  @@index([contractor_id, expires_at])
  @@index([expires_at])
}

enum DocumentType {
  INSURANCE
  CERTIFICATION
  LICENSE
  TRAINING
  HEALTH_SAFETY
  OTHER
}

// ============================================================================
// EXPORT JOBS
// ============================================================================

model ExportJob {
  id            String       @id @default(cuid())
  company_id    String
  export_type   ExportType
  status        ExportStatus @default(QUEUED)
  parameters    Json // Export configuration (date range, site, etc.)
  file_path     String? // Storage path when complete
  file_name     String?
  file_size     Int?
  error_message String?
  queued_at     DateTime     @default(now())
  run_at        DateTime     @default(now())
  attempts      Int          @default(0)
  started_at    DateTime?
  completed_at  DateTime?
  locked_at     DateTime?
  lock_token    String?
  expires_at    DateTime? // When download link expires
  requested_by  String // User ID who requested

  // Relations
  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([company_id, status])
  @@index([company_id, queued_at])
  @@index([company_id, status, run_at])
  @@index([status])
  @@index([status, run_at])
  @@index([locked_at])
  @@index([expires_at])
}

enum ExportType {
  SIGN_IN_CSV
  INDUCTION_CSV
  SITE_PACK_PDF
  COMPLIANCE_ZIP
}

enum ExportStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

// ============================================================================
// AUDIT LOG
// ============================================================================

model AuditLog {
  id          String   @id @default(cuid())
  company_id  String
  user_id     String? // null for system/anonymous actions
  action      String // e.g., "user.login", "site.create", "export.download"
  entity_type String? // e.g., "Site", "Contractor"
  entity_id   String?
  details     Json? // Additional context
  ip_address  String?
  user_agent  String?
  request_id  String?
  created_at  DateTime @default(now())

  // Relations
  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  user    User?   @relation("user_audit_logs", fields: [user_id], references: [id], onDelete: SetNull)

  // Append-only: no update/delete operations allowed at application level
  @@index([company_id])
  @@index([company_id, created_at])
  @@index([company_id, action])
  @@index([created_at])
  @@index([user_id])
  @@index([entity_type, entity_id])
  @@index([request_id])
}
