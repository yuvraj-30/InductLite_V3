  id             String       @id @default(cuid())
  company_id     String
  site_id        String
  name           String
  resource_type  ResourceType @default(OTHER)
  capacity       Int          @default(1)
  location_label String?
  notes          String?
  readiness_status ResourceReadinessStatus @default(READY)
  inspection_due_at DateTime?
  service_due_at  DateTime?
  blocked_reason  String?
  last_compliance_check_at DateTime?
  is_active      Boolean      @default(true)
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt

  @@unique([company_id, site_id, name])
  @@index([company_id])
  @@index([company_id, site_id, is_active])
  @@index([company_id, readiness_status])
  @@index([company_id, inspection_due_at])
  @@index([company_id, service_due_at])
}

model ResourceBooking {
  id                String                @id @default(cuid())
  company_id        String
  site_id           String
  resource_id       String
  title             String
  contact_name      String?
  contact_email     String?
  booked_by_user_id String?
  starts_at         DateTime
  ends_at           DateTime
  status            ResourceBookingStatus @default(CONFIRMED)
  notes             String?
  cancelled_at      DateTime?
  created_at        DateTime              @default(now())
  updated_at        DateTime              @updatedAt

  @@index([company_id])
  @@index([company_id, site_id, starts_at])
  @@index([company_id, resource_id, starts_at])
  @@index([company_id, status, starts_at])
}

enum ResourceReadinessStatus {
  READY
  REVIEW_REQUIRED
  BLOCKED
}

enum ResourceInspectionStatus {
  PASS
  FAIL
}

model ResourceInspectionRecord {
  id                  String                   @id @default(cuid())
  company_id          String
  site_id             String
  resource_id         String
  status              ResourceInspectionStatus @default(PASS)
  inspected_at        DateTime                 @default(now())
  inspected_by_user_id String?
  notes               String?
  created_at          DateTime                 @default(now())
  updated_at          DateTime                 @updatedAt

  @@index([company_id])
  @@index([company_id, site_id, inspected_at])
  @@index([company_id, resource_id, inspected_at])
}

enum InspectionFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  AD_HOC
}

enum InspectionRunStatus {
  COMPLETED
  MISSED
}

model InspectionSchedule {
  id               String              @id @default(cuid())
  company_id       String
  site_id          String
  template_id      String
  name             String
  frequency        InspectionFrequency @default(WEEKLY)
  starts_at        DateTime
  next_due_at      DateTime
  assigned_user_id String?
  is_active        Boolean             @default(true)
  created_at       DateTime            @default(now())
  updated_at       DateTime            @updatedAt

  @@index([company_id])
  @@index([company_id, site_id, is_active])
  @@index([company_id, next_due_at, is_active])
}

model InspectionRun {
  id                  String              @id @default(cuid())
  company_id          String
  site_id             String
  schedule_id         String
  submission_id       String?
  performed_by_user_id String?
  status              InspectionRunStatus @default(COMPLETED)
  score_percent       Int?
  failed_item_count   Int                 @default(0)
  summary             String?
  started_at          DateTime            @default(now())
  completed_at        DateTime?
  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt

  @@index([company_id])
  @@index([company_id, site_id, completed_at])
  @@index([company_id, schedule_id, completed_at])
}

enum SafetyFormType {
  SWMS
  JSA
  RAMS
  TOOLBOX_TALK
  FATIGUE_DECLARATION
}

enum SafetyFormSubmissionStatus {
  SUBMITTED
  REVIEWED
  REJECTED
}

model SafetyFormTemplate {
  id           String         @id @default(cuid())
  company_id   String
  site_id      String?
  name         String
  form_type    SafetyFormType
  description  String?
  field_schema Json
  is_active    Boolean        @default(true)
  created_by   String?
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt

  submissions SafetyFormSubmission[]

  @@unique([company_id, site_id, name, form_type])
  @@index([company_id])
  @@index([company_id, site_id, is_active])
  @@index([company_id, form_type, is_active])
}

model SafetyFormSubmission {
  id                 String                     @id @default(cuid())
  company_id         String
  site_id            String
  template_id        String
  sign_in_record_id  String?
  submitted_by_name  String
  submitted_by_email String?
  submitted_by_phone String?
  payload            Json
  summary            String?
  status             SafetyFormSubmissionStatus @default(SUBMITTED)
  submitted_at       DateTime                   @default(now())
  reviewed_at        DateTime?
  reviewed_by        String?
  review_notes       String?
  created_at         DateTime                   @default(now())
  updated_at         DateTime                   @updatedAt

  template SafetyFormTemplate @relation(fields: [template_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([company_id, site_id, submitted_at])
  @@index([company_id, template_id, status])
  @@index([sign_in_record_id])
}

model EvidenceManifest {
  id                  String                     @id @default(cuid())
  company_id          String
  export_job_id       String?
  hash_root           String
  signature           String
  signer              String?
  signature_algorithm EvidenceSignatureAlgorithm @default(HMAC_SHA256)
  expires_at          DateTime?
  created_at          DateTime                   @default(now())
  updated_at          DateTime                   @updatedAt

  @@index([company_id])
  @@index([company_id, export_job_id])
}

model EvidenceArtifact {
  id                   String   @id @default(cuid())
  company_id           String
  evidence_manifest_id String
  artifact_path        String
  artifact_hash        String
  artifact_size        Int
  artifact_type        String
  created_at           DateTime @default(now())

  @@index([company_id])
  @@index([company_id, evidence_manifest_id])
}

model PolicySimulation {
  id         String   @id @default(cuid())
  company_id String
  name       String
  scenario   Json
  created_by String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([company_id])
  @@index([company_id, created_at])
}

model PolicySimulationRun {
  id                    String                 @id @default(cuid())
  company_id            String
  policy_simulation_id  String
  status                PolicySimulationStatus @default(QUEUED)
  snapshot_generated_at DateTime?
  started_at            DateTime?
  completed_at          DateTime?
  requested_by          String?
  error_message         String?
  created_at            DateTime               @default(now())
  updated_at            DateTime               @updatedAt

  @@index([company_id])
  @@index([company_id, status, created_at])
  @@index([policy_simulation_id])
}

model PolicySimulationResult {
  id                       String   @id @default(cuid())
  company_id               String
  policy_simulation_run_id String   @unique
  summary                  Json
  breakdown                Json
  blocked_entries_estimate Int
  approval_load_estimate   Int
  false_positive_estimate  Int
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  @@index([company_id])
  @@index([company_id, created_at])
}

model ContractorRiskScore {
  id                 String    @id @default(cuid())
  company_id         String
  contractor_id      String
  site_id            String?
  current_score      Int       @default(0)
  components         Json?
  threshold_state    String?
  last_calculated_at DateTime?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  @@unique([company_id, contractor_id, site_id])
  @@index([company_id])
  @@index([company_id, site_id, current_score])
}

model RiskScoreHistory {
  id                       String   @id @default(cuid())
  company_id               String
  contractor_risk_score_id String
  score                    Int
  components               Json?
  calculated_at            DateTime @default(now())

  @@index([company_id])
  @@index([contractor_risk_score_id, calculated_at])
}

model PlanChangeRequest {
  id               String                  @id @default(cuid())
  company_id       String
  requested_by     String?
  target_plan      CompanyPlan
  effective_at     DateTime
  status           PlanChangeRequestStatus @default(DRAFT)
  change_payload   Json
  rollback_payload Json?
  created_at       DateTime                @default(now())
  updated_at       DateTime                @updatedAt

  @@index([company_id])
  @@index([company_id, status, effective_at])
}

model PlanChangeHistory {
  id                     String   @id @default(cuid())
  company_id             String
  plan_change_request_id String
  action                 String
  previous_state         Json?
  next_state             Json?
  acted_by               String?
  acted_at               DateTime @default(now())
  created_at             DateTime @default(now())

  @@index([company_id])
  @@index([plan_change_request_id, acted_at])
}

model OutboundWebhookDelivery {
  id                 String                @id @default(cuid())
  company_id         String
  site_id            String
  event_type         String
  target_url         String
  payload            Json
  status             WebhookDeliveryStatus @default(PENDING)
  attempts           Int                   @default(0)
  max_attempts       Int                   @default(5)
  next_attempt_at    DateTime              @default(now())
  last_attempt_at    DateTime?
  last_status_code   Int?
  last_error         String?
  last_response_body String?
  sent_at            DateTime?
  created_at         DateTime              @default(now())
  updated_at         DateTime              @updatedAt

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  site    Site    @relation(fields: [site_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([company_id, status])
  @@index([status, next_attempt_at])
  @@index([site_id, status])
  @@index([created_at])
}

enum WebhookDeliveryStatus {
  PENDING
  PROCESSING
  RETRYING
  SENT
  DEAD
}

// ============================================================================
// CONTRACTORS & DOCUMENTS
// ============================================================================

model Contractor {
  id            String   @id @default(cuid())
  company_id    String
  name          String // Company/individual name
  contact_name  String?
  contact_email String?
  contact_phone String?
  trade         String? // e.g., Electrician, Plumber
  notes         String?
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Relations
  company           Company              @relation(fields: [company_id], references: [id], onDelete: Cascade)
  documents         ContractorDocument[]
  magic_link_tokens MagicLinkToken[]

  @@unique([company_id, name])
  @@index([company_id])
  @@index([company_id, contact_email])
  @@index([company_id, is_active])
}

model SiteManagerAssignment {
  id         String   @id @default(cuid())
  company_id String
  site_id    String
  user_id    String
  created_at DateTime @default(now())

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  site    Site    @relation("site_manager_site", fields: [site_id], references: [id], onDelete: Cascade)
  user    User    @relation("site_manager_user", fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([company_id, site_id, user_id])
  @@index([company_id])
  @@index([company_id, user_id])
  @@index([company_id, site_id])
}

model MagicLinkToken {
  id            String    @id @default(cuid())
  company_id    String
  contractor_id String
  token_hash    String    @unique
  expires_at    DateTime
  used_at       DateTime?
  created_at    DateTime  @default(now())

  company    Company    @relation(fields: [company_id], references: [id], onDelete: Cascade)
  contractor Contractor @relation(fields: [contractor_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([company_id, contractor_id])
  @@index([expires_at])
}

model ContractorDocument {
  id            String       @id @default(cuid())
  contractor_id String
  document_type DocumentType
  file_name     String
  file_path     String // Storage path (S3 key or local path)
  file_size     Int // bytes
  mime_type     String
  expires_at    DateTime? // null = no expiry
  uploaded_at   DateTime     @default(now())
  notes         String?

  // Relations
  contractor Contractor @relation(fields: [contractor_id], references: [id], onDelete: Cascade)

  @@index([contractor_id])
  @@index([contractor_id, expires_at])
  @@index([expires_at])
}

enum DocumentType {
  INSURANCE
  CERTIFICATION
  LICENSE
  TRAINING
  HEALTH_SAFETY
  OTHER
}

// ============================================================================
// EXPORT JOBS
// ============================================================================

model ExportJob {
  id            String       @id @default(cuid())
  company_id    String
  export_type   ExportType
  status        ExportStatus @default(QUEUED)
  parameters    Json // Export configuration (date range, site, etc.)
  file_path     String? // Storage path when complete
  file_name     String?
  file_size     Int?
  error_message String?
  queued_at     DateTime     @default(now())
  run_at        DateTime     @default(now())
  attempts      Int          @default(0)
  started_at    DateTime?
  completed_at  DateTime?
  locked_at     DateTime?
  lock_token    String?
  expires_at    DateTime? // When download link expires
  requested_by  String // User ID who requested

  // Relations
  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([company_id, status])
  @@index([company_id, queued_at])
  @@index([company_id, status, run_at])
  @@index([status])
  @@index([status, run_at])
  @@index([locked_at])
  @@index([expires_at])
}

enum ExportType {
  SIGN_IN_CSV
  INDUCTION_CSV
  SITE_PACK_PDF
  COMPLIANCE_ZIP
}

enum ExportStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

// ============================================================================
// AUDIT LOG
// ============================================================================

model AuditLog {
  id          String   @id @default(cuid())
  company_id  String
  user_id     String? // null for system/anonymous actions
  action      String // e.g., "user.login", "site.create", "export.download"
  entity_type String? // e.g., "Site", "Contractor"
  entity_id   String?
  details     Json? // Additional context
  ip_address  String?
  user_agent  String?
  request_id  String?
  created_at  DateTime @default(now())

  // Relations
  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  user    User?   @relation("user_audit_logs", fields: [user_id], references: [id], onDelete: SetNull)

  // Append-only: no update/delete operations allowed at application level
  @@index([company_id])
  @@index([company_id, created_at])
  @@index([company_id, action])
  @@index([created_at])
  @@index([user_id])
  @@index([entity_type, entity_id])
  @@index([request_id])
}
