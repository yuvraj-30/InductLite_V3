{
  "name": "inductlite",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "npm run lint && npm run typecheck && turbo run build",
    "build:strict": "npm run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "test:coverage": "turbo run test:coverage",
    "test:confidence": "node tools/test-confidence-gate.mjs",
    "test:confidence:full": "node tools/test-confidence-gate.mjs --full",
    "test:gap-matrix": "node tools/test-gap-matrix.mjs",
    "test:e2e:gap-matrix": "node tools/e2e-gap-matrix.mjs",
    "test:e2e:smoke": "turbo run test:e2e:smoke",
    "test:e2e:full": "turbo run test:e2e:full",
    "test:e2e:full:all": "turbo run test:e2e:full:all",
    "test:e2e:ci-local": "powershell -ExecutionPolicy Bypass -File .\\tools\\run-ci-e2e-local.ps1",
    "test:e2e:perf-budget": "npm run -w apps/web test:e2e:perf-budget",
    "test:visual": "turbo run test:visual",
    "report:ux-perf-budget": "node tools/uiux-performance-budget-report.mjs",
    "report:ux-kpi-readout": "node tools/uiux-kpi-readout.mjs",
    "guardrails-lint": "node scripts/guardrails-lint.mjs",
    "guardrails-tests": "node scripts/guardrails-tests.mjs && npm run -w apps/web test -- src/lib/cost/__tests__/compute-counters.test.ts src/lib/api/__tests__/response.guardrails.test.ts",
    "policy-check": "node scripts/policy-check.mjs",
    "parity-gate": "node tools/parity-gate.mjs",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:status": "npm run -w apps/web db:status",
    "db:push": "turbo run db:push",
    "db:seed": "turbo run db:seed",
    "db:studio": "turbo run db:studio",
    "mobile:start": "npm run -w apps/mobile start",
    "mobile:ios": "npm run -w apps/mobile ios",
    "mobile:android": "npm run -w apps/mobile android",
    "mobile:typecheck": "npm run -w apps/mobile typecheck",
    "mobile:release:check": "npm run -w apps/mobile release:check",
    "mobile:prebuild": "npm run -w apps/mobile prebuild",
    "vrt:up": "docker compose -f ./docker-compose.vrt.yml up -d",
    "vrt:down": "docker compose -f ./docker-compose.vrt.yml down --volumes",
    "vrt:logs": "docker compose -f ./docker-compose.vrt.yml logs -f"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testcontainers/postgresql": "^11.12.0",
    "@types/deep-eql": "^4.0.2",
    "@types/docker-modem": "^3.0.6",
    "@types/readdir-glob": "^1.1.5",
    "@types/ssh2-streams": "^0.1.13",
    "testcontainers": "^11.12.0",
    "turbo": "^2.8.14",
    "typescript": "^5.3.3"
  },
  "packageManager": "npm@10.2.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": "24.x"
  },
  "overrides": {
    "undici": "7.24.1",
    "basic-ftp": "5.2.0",
    "fast-xml-parser": "5.3.8",
    "lodash": "4.17.23",
    "serialize-javascript": "7.0.3",
    "extract-zip": "file:tools/vendor/extract-zip",
    "@aws-sdk/xml-builder": {
      "fast-xml-parser": "5.3.8"
    },
    "@aws-sdk/xml-builder@3.972.8": {
      "fast-xml-parser": "5.3.8"
    },
    "terser-webpack-plugin": {
      "serialize-javascript": "7.0.3"
    },
    "@rollup/plugin-terser": {
      "serialize-javascript": "7.0.3"
    },
    "rollup@2.79.2": "2.80.0",
    "rollup@4.57.1": "4.59.0",
    "minimatch@3.1.2": "3.1.3",
    "minimatch@5.1.6": "5.1.8",
    "minimatch@9.0.5": "9.0.7"
  }
}
